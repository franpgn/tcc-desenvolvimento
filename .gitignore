# Build Java / Maven
target/
*.class
*.jar
!**/lib/*.jar
.classpath
.project
.settings/

# IDEs
.idea/
*.iml
.vscode/
.metadata/

# Resultados experimentais (ver D-005 em docs/planejamento-inicial.md)
runs/*/raw/
runs/**/*.csv
runs/**/*.log
runs/**/*.txt
!runs/**/summary.json
!runs/**/.gitkeep

# TLC
spec/states/
spec/*.tlaplus.skip
spec/MC.out
spec/MC.tla
spec/MC.cfg

# Logs
*.log
logs/

# Saídas temporárias
*.tmp
*.swp
*.bak
*~

# Python (analysis/)
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env

# Sistema
.DS_Store
Thumbs.db

# Resultados de TLC: permitir trace, output e summary.json em qualquer subpasta
# tlc* (rodada de referência, sondas com invariantes desabilitados, etc.).
# Ignora apenas o diretório states/ interno do TLC, que pode crescer indefinidamente.
!runs/tlc*/**/SessionStore_TTrace_*.tla
!runs/tlc*/**/output.txt
!runs/tlc*/**/contraexemplo*.txt
runs/tlc*/**/states/
