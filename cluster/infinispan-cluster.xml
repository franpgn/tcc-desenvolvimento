<?xml version="1.0" encoding="UTF-8"?>
<!--
  Configuração do cluster Infinispan para o TCC.
  Cache 'sessions' em modo DIST_SYNC, numOwners=2, numSegments=64.
  Mantém duas cópias por chave para tolerar falha de um nó.
  Statistics habilitado para captura por OpenMetrics.

  Para cenários com replicação assíncrona, alternar mode="ASYNC".
-->
<infinispan
    xmlns="urn:infinispan:config:15.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="urn:infinispan:config:15.0 https://infinispan.org/schemas/infinispan-config-15.0.xsd">

  <jgroups>
    <stack-file name="cluster-stack" path="jgroups-tcp.xml"/>
  </jgroups>

  <cache-container name="default" statistics="true">
    <transport cluster="cluster-tcc" stack="cluster-stack"/>

    <distributed-cache name="sessions" mode="SYNC" owners="2" segments="64" statistics="true">
      <locking concurrency-level="1000" acquire-timeout="15000" striping="false"/>
      <state-transfer enabled="true" timeout="60000"/>
      <partition-handling when-split="DENY_READ_WRITES" merge-policy="PREFERRED_NON_NULL"/>
    </distributed-cache>

    <distributed-cache name="counters" mode="SYNC" owners="2" segments="64" statistics="true">
      <locking concurrency-level="1000" acquire-timeout="15000" striping="false"/>
      <state-transfer enabled="true" timeout="60000"/>
      <partition-handling when-split="DENY_READ_WRITES" merge-policy="PREFERRED_NON_NULL"/>
    </distributed-cache>
  </cache-container>

  <server xmlns="urn:infinispan:server:15.0">
    <interfaces>
      <interface name="public">
        <inet-address value="${infinispan.bind.address:0.0.0.0}"/>
      </interface>
    </interfaces>
    <socket-bindings default-interface="public" port-offset="${infinispan.socket.binding.port-offset:0}">
      <socket-binding name="default" port="${infinispan.bind.port:11222}"/>
    </socket-bindings>
    <security>
      <security-realms>
        <security-realm name="default">
          <properties-realm/>
        </security-realm>
      </security-realms>
    </security>
    <!--
      O conector Hot Rod anuncia para o cliente um endereco externo
      (external-host/external-port) em vez do IP interno do container
      (10.89.x.x), que e inalcancavel a partir do host Windows/WSL2. Sem
      isso, o cliente recebe a topologia com os IPs internos dos owners e
      falha com ISPN004015 (Failed adding new server 10.89.x.x), gerando
      ERROR_TRANSPORT em ~2/3 das chaves. Os valores sao parametrizados por
      propriedade de sistema, definida por no no podman-compose.yml:
        isn1 -> 127.0.0.1:11222, isn2 -> 127.0.0.1:11223, isn3 -> 127.0.0.1:11224
    -->
    <endpoints>
      <endpoint socket-binding="default" security-realm="default">
        <hotrod-connector
            external-host="${infinispan.hotrod.external-host:127.0.0.1}"
            external-port="${infinispan.hotrod.external-port:11222}"/>
        <rest-connector/>
      </endpoint>
    </endpoints>
  </server>
</infinispan>
